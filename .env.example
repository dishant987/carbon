# Server Configuration
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/carbon_footprint"

# Google Gemini AI
GEMINI_API_KEY="your-gemini-api-key-here"

# JWT Secrets (use long random strings)
JWT_SECRET="change-this-to-a-long-random-secret-string"
JWT_REFRESH_SECRET="change-this-to-another-long-random-secret-string"

# Redis (optional — caching falls back gracefully if unavailable)
REDIS_HOST="localhost"
REDIS_PORT=6379

# Client URL (for CORS)
CLIENT_URL="http://localhost:5173"
