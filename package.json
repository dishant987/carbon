{
  "name": "carbon-footprint-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Carbon Footprint Awareness Platform",
  "scripts": {
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "install:all": "cd server && npm install && cd ../client && npm install",
    "db:setup": "cd server && npx prisma db push",
    "lint": "eslint \"server/src/**/*.ts\" \"client/src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"server/src/**/*.ts\" \"client/src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"server/src/**/*.ts\" \"client/src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"server/src/**/*.ts\" \"client/src/**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.8.4"
  }
}
